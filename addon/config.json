{
  "name": "Wiresheet Flow Editor",
  "version": "1.0.0",
  "slug": "wiresheet",
  "description": "Visueller Flow-Editor für Home Assistant - Programmiere mit Bausteinen wie in Niagara",
  "arch": ["aarch64", "amd64", "armhf", "armv7", "i386"],
  "startup": "application",
  "boot": "auto",
  "init": false,
  "ports": {
    "8099": 8099
  },
  "ports_description": {
    "8099": "Web-Interface für Wiresheet Editor"
  },
  "webui": "http://[HOST]:[PORT:8099]",
  "panel_icon": "mdi:wire",
  "panel_title": "Wiresheet",
  "hassio_api": true,
  "hassio_role": "default",
  "homeassistant_api": true,
  "ingress": true,
  "ingress_port": 8099,
  "auth_api": true,
  "options": {
    "log_level": "info",
    "ssl": false
  },
  "schema": {
    "log_level": "list(trace|debug|info|notice|warning|error|fatal)?",
    "ssl": "bool?",
    "certfile": "str?",
    "keyfile": "str?"
  },
  "image": "ghcr.io/homeassistant/{arch}-addon-wiresheet"
}
