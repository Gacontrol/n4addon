{
  "name": "Wiresheet Flow Editor",
  "version": "1.0.2",
  "slug": "wiresheet",
  "description": "Visual Flow Editor for Home Assistant",
  "arch": ["aarch64", "amd64", "armhf", "armv7", "i386"],
  "startup": "application",
  "boot": "auto",
  "init": false,
  "ingress": true,
  "ingress_port": 8099,
  "ports": {
    "8098/tcp": 8098
  },
  "ports_description": {
    "8098/tcp": "Visualization Dashboard (direct access)"
  },
  "panel_icon": "mdi:sitemap",
  "panel_title": "Wiresheet",
  "hassio_api": true,
  "hassio_role": "default",
  "homeassistant_api": true,
  "auth_api": true,
  "host_network": true,
  "map": ["config:rw", "share:rw"],
  "options": {
    "log_level": "info"
  },
  "schema": {
    "log_level": "list(trace|debug|info|notice|warning|error|fatal)?"
  }
}
