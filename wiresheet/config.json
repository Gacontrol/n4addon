{
  "name": "GA-Control",
  "version": "1.0.6",
  "slug": "ga-control",
  "description": "keep it simple - by Dr. Muff",
  "arch": ["aarch64", "amd64", "armhf", "armv7", "i386"],
  "startup": "application",
  "boot": "auto",
  "init": false,
  "ingress": true,
  "ingress_port": 8099,
  "panel_icon": "mdi:sitemap",
  "panel_title": "GA-Control",
  "hassio_api": true,
  "hassio_role": "default",
  "homeassistant_api": true,
  "auth_api": true,
  "host_network": true,
  "map": ["config:rw", "share:rw"],
  "options": {
    "log_level": "info"
  },
  "schema": {
    "log_level": "list(trace|debug|info|notice|warning|error|fatal)?"
  }
}
